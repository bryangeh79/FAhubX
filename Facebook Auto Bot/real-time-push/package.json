{
  "name": "facebook-auto-bot-real-time-push",
  "version": "1.0.0",
  "description": "Real-time push system for Facebook Auto Bot",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:dev": "ts-node src/index.ts",
    "dev": "nodemon --exec ts-node src/index.ts",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "dependencies": {
    "ioredis": "^5.3.0",
    "socket.io-client": "^4.7.0",
    "axios": "^1.6.0",
    "winston": "^3.9.0",
    "bull": "^4.11.0",
    "lodash": "^4.17.21",
    "date-fns": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ioredis": "^5.0.0",
    "@types/socket.io-client": "^3.0.0",
    "@types/lodash": "^4.17.0",
    "typescript": "^5.0.0",
    "ts-node": "^10.0.0",
    "nodemon": "^3.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "jest": "^29.5.0",
    "@types/jest": "^29.5.0",
    "ts-jest": "^29.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}