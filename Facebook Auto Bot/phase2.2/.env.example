# Facebook Auto Bot Phase 2.2 - 环境变量配置示例

# ====================
# 应用配置
# ====================
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
LOG_CONSOLE=true
LOG_FILE=false
LOG_FILE_PATH=./logs/app.log

# ====================
# 数据库配置 (PostgreSQL)
# ====================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=facebook_bot
DB_USER=postgres
DB_PASSWORD=your_database_password
DB_SSL=false
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=10000

# ====================
# Redis配置 (可选)
# ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=fb:
REDIS_TLS=false

# ====================
# 会话加密配置
# ====================
# 生成32字节base64密钥: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_ENCRYPTION_KEY=your_32_byte_base64_encryption_key_here
SESSION_ENCRYPTION_IV_LENGTH=12
SESSION_ENCRYPTION_SALT_LENGTH=16
SESSION_CLEANUP_INTERVAL=3600000
SESSION_MAX_IDLE_TIME=86400000
SESSION_TTL=604800000

# ====================
# VPN/IP配置
# ====================
VPN_ROTATION_STRATEGY=round-robin
VPN_MIN_ROTATION_INTERVAL=60000
VPN_MAX_SESSIONS_PER_IP=1
VPN_HEALTH_CHECK_INTERVAL=300000

# VPN地理位置限制 (JSON格式)
VPN_GEO_RESTRICTIONS={"allowedCountries":["US","CA","GB","DE","FR"],"blockedCountries":["RU","CN","KP","IR"]}

# VPN性能阈值 (JSON格式)
VPN_PERFORMANCE_THRESHOLD={"minDownloadSpeed":10,"maxPing":200,"maxPacketLoss":5}

# VPN配置列表 (JSON格式)
# VPN_CONFIGS=[{"type":"openvpn","name":"us-vpn","configPath":"/configs/us.ovpn"},{"type":"wireguard","name":"eu-vpn","configPath":"/configs/eu.conf"}]

# ====================
# 健康检查配置
# ====================
HEALTH_CHECK_INTERVAL=300000
FACEBOOK_CHECK_INTERVAL=600000
RISK_THRESHOLD_WARNING=30
RISK_THRESHOLD_CRITICAL=60
RISK_THRESHOLD_BAN=80
AUTO_FIX_ENABLED=true
NOTIFICATION_ENABLED=true
HEALTH_CHECK_TYPES=login_status,post_ability,rate_limit,ip_reputation,behavior_analysis

# ====================
# 监控告警配置
# ====================
# Slack通知
SLACK_WEBHOOK_URL=your-slack-webhook-url-here
SLACK_CHANNEL=#alerts

# Email通知
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=monitoring@example.com
EMAIL_TO=admin@example.com,team@example.com

# 告警规则 (JSON格式)
# MONITORING_ALERT_RULES=[{"name":"High Error Rate","severity":"error","conditions":[{"metric":"error_rate","operator":">","value":0.1}],"notificationChannels":["slack"]}]

# ====================
# 网络配置
# ====================
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
DNS_SERVERS=8.8.8.8,1.1.1.1
NETWORK_MTU=1500

# ====================
# 功能标志 (JSON格式)
# ====================
# FEATURE_FLAGS={"advanced_monitoring":true,"ai_analysis":false,"multi_region":true}

# ====================
# 外部API密钥
# ====================
# IP信息查询服务 (可选)
IP_API_KEY=your_ip_api_key
# 2Captcha服务 (用于验证码)
TWO_CAPTCHA_API_KEY=your_2captcha_api_key
# 其他服务密钥...

# ====================
# 调试配置
# ====================
DEBUG=false
VERBOSE_LOGGING=false
ENABLE_METRICS=true
ENABLE_AUDIT=true

# ====================
# Docker配置
# ====================
DOCKER_NETWORK_DRIVER=bridge
DOCKER_NETWORK_SUBNET=172.18.0.0/16
DOCKER_VOLUME_PATH=/var/lib/facebook-bot

# ====================
# 安全配置
# ====================
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=24h
API_KEY=your_api_key_here
ENABLE_RATE_LIMIT=true
ENABLE_CORS=true
ENABLE_HTTPS=false
SSL_CERT_PATH=/path/to/cert.pem
SSL_KEY_PATH=/path/to/key.pem

# 注意：
# 1. 将所有的 "your_*" 替换为实际的值
# 2. 生产环境务必使用强密码和密钥
# 3. 敏感信息应通过密钥管理服务管理
# 4. 定期轮换加密密钥和API密钥