# Facebook Auto Bot 环境变量配置
# 复制此文件为 .env 并根据需要修改

# ========== 应用配置 ==========
NODE_ENV=development
APP_NAME=Facebook Auto Bot
APP_VERSION=1.0.0
PORT=3000
HOST=0.0.0.0
API_PREFIX=/api/v1
FRONTEND_URL=http://localhost:8080
BACKEND_URL=http://localhost:3000

# ========== 数据库配置 ==========
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fbautobot
DB_USER=postgres
DB_PASSWORD=password
DB_SYNC=false
DB_LOGGING=false
DB_SSL=false

# ========== Redis 配置 ==========
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# ========== RabbitMQ 配置 ==========
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=password
RABBITMQ_QUEUE_PREFIX=fbautobot

# ========== MinIO 配置 ==========
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=fbautobot
MINIO_REGION=us-east-1
MINIO_USE_SSL=false

# ========== JWT 配置 ==========
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# ========== 加密配置 ==========
ENCRYPTION_KEY=your-32-character-encryption-key-here
ENCRYPTION_IV=your-16-character-iv-here

# ========== 会话配置 ==========
SESSION_SECRET=your-session-secret-key-change-in-production
SESSION_MAX_AGE=86400000 # 24小时

# ========== 限流配置 ==========
RATE_LIMIT_WINDOW=900000 # 15分钟
RATE_LIMIT_MAX=100 # 每个窗口最大请求数

# ========== CORS 配置 ==========
CORS_ORIGIN=http://localhost:8080
CORS_CREDENTIALS=true

# ========== 日志配置 ==========
LOG_LEVEL=info
LOG_FORMAT=combined
LOG_DIR=./logs

# ========== 监控配置 ==========
PROMETHEUS_METRICS_PATH=/metrics
PROMETHEUS_DEFAULT_METRICS=true

# ========== 任务配置 ==========
TASK_MAX_CONCURRENT=10
TASK_RETRY_MAX_ATTEMPTS=3
TASK_RETRY_DELAY=300000 # 5分钟
TASK_TIMEOUT=1800000 # 30分钟

# ========== Facebook 配置 ==========
# 注意：这些是示例值，需要替换为实际的 Facebook App 配置
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_APP_VERSION=v18.0
FACEBOOK_REDIRECT_URI=http://localhost:3000/api/v1/auth/facebook/callback
FACEBOOK_SCOPE=email,public_profile,pages_manage_posts,pages_read_engagement

# ========== 邮件配置 ==========
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@fbautobot.com

# ========== 管理员配置 ==========
ADMIN_EMAIL=admin@fbautobot.com
ADMIN_PASSWORD=Admin123!

# ========== 开发工具配置 ==========
DEBUG=true
TYPEORM_DEBUG=false
SWAGGER_ENABLED=true
SWAGGER_PATH=/api-docs

# ========== 安全配置 ==========
HELMET_ENABLED=true
CSRF_ENABLED=false
CONTENT_SECURITY_POLICY=true
HSTS_ENABLED=true

# ========== 性能配置 ==========
COMPRESSION_ENABLED=true
CACHE_CONTROL=true
RESPONSE_TIME=true

# ========== 测试配置 ==========
TEST_DB_NAME=fbautobot_test
TEST_DB_SYNC=true
TEST_DB_DROP_SCHEMA=true