# Facebook Auto Bot 生产环境配置
# 复制此文件为 .env.production 并修改相应值

# ====================
# 数据库配置
# ====================
DB_NAME=fbautobot_production
DB_USER=fbautobot_user
DB_PASSWORD=your_secure_password_here
DB_HOST=postgres
DB_PORT=5432

# ====================
# Redis 配置
# ====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# ====================
# RabbitMQ 配置
# ====================
RABBITMQ_USER=admin
RABBITMQ_PASS=your_rabbitmq_password_here

# ====================
# MinIO 配置
# ====================
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key

# ====================
# JWT 配置
# ====================
JWT_SECRET=your_super_secure_jwt_secret_here
JWT_EXPIRES_IN=7d

# ====================
# 应用配置
# ====================
API_URL=https://api.yourdomain.com
WS_URL=wss://api.yourdomain.com
NODE_ENV=production
PORT=3000

# ====================
# 监控配置
# ====================
GRAFANA_ADMIN_PASSWORD=admin_password_here
PROMETHEUS_RETENTION=30d
LOKI_RETENTION=720h

# ====================
# 部署配置
# ====================
TAG=v1.0.0

# ====================
# 性能配置
# ====================
WORKER_CONCURRENCY=5
MAX_REQUEST_SIZE=10mb
REQUEST_TIMEOUT=300000

# ====================
# 安全配置
# ====================
CORS_ORIGIN=https://yourdomain.com
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX=100

# ====================
# 日志配置
# ====================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=/var/log/backend/application.log

# ====================
# 备份配置
# ====================
BACKUP_SCHEDULE="0 2 * * *"  # 每天凌晨2点
BACKUP_RETENTION_DAYS=30

# ====================
# 邮件通知配置
# ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password
ALERT_EMAIL=admin@yourdomain.com