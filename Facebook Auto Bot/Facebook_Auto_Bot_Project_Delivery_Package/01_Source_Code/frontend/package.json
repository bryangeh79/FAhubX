{
  "name": "facebook-auto-bot-frontend",
  "version": "1.0.0",
  "description": "Facebook Auto Bot SaaS Platform - Frontend",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,scss}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "type-check": "tsc --noEmit",
    "preview:prod": "vite preview --port 4173 --host",
    "pwa:test": "node -e \"console.log('运行 PWA 测试: 请访问 /pwa-test 页面')\"",
    "pwa:audit": "node -e \"console.log('运行 Lighthouse 审计: 请使用 Chrome DevTools')\"",
    "pwa:icons": "node -e \"console.log('生成 PWA 图标: 请查看 public/README_ICONS.md')\"",
    "pwa:validate": "node -e \"console.log('验证 PWA 配置: 请访问 https://www.pwabuilder.com/')\""
  },
  "dependencies": {
    "@ant-design/icons": "^5.2.0",
    "@ant-design/pro-components": "^2.6.0",
    "@hookform/resolvers": "^3.1.0",
    "antd": "^5.7.0",
    "axios": "^1.4.0",
    "cronstrue": "^3.14.0",
    "dayjs": "^1.11.0",
    "lodash-es": "^4.17.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-error-boundary": "^4.0.0",
    "react-helmet-async": "^2.0.0",
    "react-hook-form": "^7.45.0",
    "react-intl": "^6.4.0",
    "react-query": "^3.39.0",
    "react-router-dom": "^6.14.0",
    "recharts": "^2.7.0",
    "workbox-core": "^7.0.0",
    "workbox-precaching": "^7.0.0",
    "workbox-routing": "^7.0.0",
    "workbox-strategies": "^7.0.0",
    "zod": "^3.21.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.45.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "jsdom": "^22.0.0",
    "postcss": "^8.4.0",
    "prettier": "^3.0.0",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.0.0",
    "vite": "^4.4.0",
    "vite-plugin-pwa": "^0.16.0",
    "vitest": "^0.34.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
