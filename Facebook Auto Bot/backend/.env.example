# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=facebook_auto_bot
DB_SYNCHRONIZE=false

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=3600

# VPN Configuration
VPN_CONFIG_DIR=/etc/vpn/configs
VPN_LOG_DIR=/var/log/vpn
VPN_MAX_CONNECTIONS=100

# IP Pool Configuration
IP_POOL_MIN_HEALTH_SCORE=50
IP_POOL_HEALTH_CHECK_INTERVAL=300000
IP_POOL_CLEANUP_INTERVAL=86400000

# Network Monitoring
NETWORK_MONITOR_INTERVAL=300000
NETWORK_ALERT_THRESHOLD_LATENCY=300
NETWORK_ALERT_THRESHOLD_PACKET_LOSS=20
NETWORK_ALERT_THRESHOLD_HEALTH_SCORE=50

# Automation Rules
AUTOMATION_ENABLED=true
AUTOMATION_CHECK_INTERVAL=600000
AUTOMATION_MAX_CONCURRENT=10

# Security
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info
LOG_FILE=/var/log/facebook-auto-bot/backend.log

# Task Queue
TASK_RETRY_MAX_ATTEMPTS=3
TASK_RETRY_DELAY=300000
TASK_TIMEOUT=1800000

# Development
NODE_ENV=development
PORT=3000