{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@/*": ["src/*"],
      "@common/*": ["src/common/*"],
      "@modules/*": ["src/modules/*"],
      "@database/*": ["src/database/*"],
      "@config/*": ["src/config/*"],
      "@shared/*": ["src/shared/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "**/*.spec.ts",
    "**/*.test.ts",
    "src/modules/vpn-client/**/*",
    "src/modules/vpn-integration/**/*",
    "src/modules/task-scheduler/**/*",
    "src/modules/task-queue/**/*",
    "src/modules/task-executor/**/*",
    "src/modules/account-manager/**/*",
    "src/modules/task-monitor/**/*",
    "src/modules/batch-operations/**/*",
    "src/modules/account-batch/**/*",
    "src/modules/account-health/**/*",
    "src/modules/account-recovery/**/*",
    "src/database/migrations/**/*"
  ]
}