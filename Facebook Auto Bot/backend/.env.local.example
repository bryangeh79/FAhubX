# Facebook Auto Bot 本地环境变量配置
# 复制此文件为 .env.local 并修改值
# 注意: .env.local 不应提交到版本控制

# ====================
# 应用配置
# ====================

# 应用环境
NODE_ENV=development

# 应用端口
PORT=3000

# 应用URL
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:8080

# ====================
# 数据库配置 (PostgreSQL)
# ====================

# 开发环境数据库 - 请使用强密码
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fbautobot
DB_USER=postgres
DB_PASSWORD=your-strong-db-password-here

# 测试环境数据库 - 请使用不同的强密码
TEST_DB_HOST=localhost
TEST_DB_PORT=5432
TEST_DB_NAME=fbautobot_test
TEST_DB_USER=postgres
TEST_DB_PASSWORD=your-strong-test-db-password-here

# ====================
# Redis配置
# ====================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password-here
REDIS_DB=0

# ====================
# RabbitMQ配置
# ====================

RABBITMQ_URL=amqp://admin:your-rabbitmq-password-here@localhost:5672
RABBITMQ_QUEUE_PREFIX=fbautobot

# ====================
# MinIO配置 (对象存储)
# ====================

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET=fbautobot

# ====================
# JWT认证配置
# ====================

# JWT密钥 - 请使用强随机字符串
JWT_SECRET=your-strong-jwt-secret-key-here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-strong-refresh-jwt-secret-key-here
JWT_REFRESH_EXPIRES_IN=30d

# ====================
# 加密配置
# ====================

# 数据加密密钥 - 32字符
ENCRYPTION_SECRET=your-32-character-encryption-secret-key-here

# ====================
# Facebook API配置
# ====================

# Facebook应用ID
FACEBOOK_APP_ID=your-facebook-app-id-here
FACEBOOK_APP_SECRET=your-facebook-app-secret-here
FACEBOOK_API_VERSION=v18.0

# ====================
# 邮件配置
# ====================

SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your-mailtrap-user
SMTP_PASS=your-mailtrap-pass
SMTP_FROM=noreply@fbautobot.com

# ====================
# 安全配置
# ====================

# CORS配置
CORS_ORIGIN=http://localhost:8080
CORS_CREDENTIALS=true

# 会话超时时间 (分钟)
SESSION_TIMEOUT=30

# 密码策略
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SYMBOLS=true

# 登录失败限制
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15